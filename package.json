{
  "name": "koami",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "KOAMI PoC — GIVC × Ontology interactive demo (KT DS AX컨설팅팀)",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --port 4173",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.worker.json",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "deploy:cf": "pnpm build && wrangler deploy",
    "deploy:dryrun": "pnpm build && wrangler deploy --dry-run",
    "serve:offline": "vite preview --port 4173",
    "poc:schema": "wrangler d1 execute koami-givc-poc --file scripts/poc/schema-poc.sql --remote",
    "poc:seed": "node scripts/ingest/poc-toluene.mjs --graph-only",
    "poc:graph": "node scripts/poc/bench-graph.mjs",
    "poc:vec": "node --env-file-if-exists=.dev.vars scripts/poc/bench-vectorize.mjs",
    "poc:ingest": "node --env-file-if-exists=.dev.vars scripts/ingest/poc-toluene.mjs",
    "poc:snapshot": "node scripts/poc/build-snapshot.mjs",
    "db:migrate": "wrangler d1 execute koami-givc-poc --remote --file migrations/0001_koami_givc.sql && wrangler d1 execute koami-givc-poc --remote --file migrations/0002_fts.sql",
    "db:migrate:local": "wrangler d1 execute koami-givc-poc --local --file migrations/0001_koami_givc.sql && wrangler d1 execute koami-givc-poc --local --file migrations/0002_fts.sql",
    "ingest:trade": "node --env-file-if-exists=.dev.vars scripts/ingest/ingest-trade.mjs",
    "ingest:companies": "node --env-file-if-exists=.dev.vars scripts/ingest/ingest-companies.mjs",
    "ingest:graph": "node scripts/ingest/build-graph.mjs",
    "ingest:fts": "node scripts/ingest/ingest-fts.mjs",
    "ingest:vec": "node --env-file-if-exists=.dev.vars scripts/ingest/ingest-vectorize.mjs",
    "ingest:all": "node --env-file-if-exists=.dev.vars scripts/ingest/ingest-all.mjs",
    "ingest:snapshot": "node scripts/ingest/build-snapshot.mjs",
    "smoke:queries": "node scripts/ingest/smoke-queries.mjs --local",
    "db:migrate:gvc": "wrangler d1 execute koami-givc-poc --local --file migrations/0003_gvc_mirror.sql",
    "db:migrate:gvc:remote": "wrangler d1 execute koami-givc-poc --remote --file migrations/0003_gvc_mirror.sql",
    "ingest:gvc": "node scripts/ingest/gvc-seed.mjs --local",
    "ingest:gvc:remote": "node scripts/ingest/gvc-seed.mjs",
    "ingest:gvc:integrity": "node scripts/ingest/gvc-integrity.mjs --local"
  },
  "dependencies": {
    "@ktds-axbd/harness-kit": "^0.12.0",
    "hono": "^4.12.22",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260524.1",
    "@types/node": "^25.9.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^8.57.1",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.14",
    "jsdom": "^25.0.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.5",
    "wrangler": "^4.94.0"
  },
  "engines": {
    "node": ">=18.18.0"
  },
  "packageManager": "pnpm@9.12.3"
}
